data/
Notebook/
temp_uploads/
langchain_qdrant/
qdrant_storage/
pgdata/
redisdata/
**/*.sqlite
**/*.db
**/*.ipynb
**/*.pdf
**/*.docx
**/*.pptx

# Credentials – mount at runtime, don’t copy
app/credentials/*
tokens/*

# Node / web (if any)
node_modules/
